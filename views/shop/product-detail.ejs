<%- include('../includes/head') %>
<%- include('../includes/navigation') %>

<main>

    <% if (product) { %>

        <article class="card product-item">

            <header class="card__header">

                <h1 class="product__title">
                    <%= product.title %>
                </h1>

            </header>

            <div class="card__actions">

                <a href="/" class="btn">
                    Back to Shop
                </a>

            </div>

        </article>

    <% } else { %>

        <h1>Product Not Found!</h1>

    <% } %>

</main>

<%- include('../includes/end') %>